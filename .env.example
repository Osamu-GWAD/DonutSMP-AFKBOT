#ACCOUNT_EMAIL_1=
#ACCOUNT_EMAIL_2=
#ACCOUNT_EMAIL_3=
# Keeps the account active so servers that pause fully idle players continue
# counting playtime.
ANTI_IDLE_ENABLED=true
ANTI_IDLE_INTERVAL_MS=600000
ANTI_IDLE_MOVE_MS=500

# Runs after spawn and then every 30 minutes.
AFK_COMMAND=/afk 41
AFK_COMMAND_INTERVAL_MS=1800000

# API playtime monitoring. If neither DonutStats nor DonutX reports an
# increased playtime for 10 minutes, that account reconnects.
PLAYTIME_POLL_INTERVAL_MS=30000
PLAYTIME_STALE_RECONNECT_MS=600000
PLAYTIME_REPORT_INTERVAL_MS=600000
API_TIMEOUT_MS=15000
MAX_REASONABLE_PLAYTIME_MS=315360000000

# DonutStats may require a fresh Cloudflare cookie from your browser.
# Paste only the cookie value, not "-H" or curl syntax.
DONUTSTATS_COOKIE=
DONUTSTATS_NEXT_ACTION=70b6cd1f1ed49054eb4e88063e90a023eeb711ea36

# Discord bot controls/logging.
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_COMMAND_PREFIX=!
